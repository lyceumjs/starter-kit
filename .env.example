# Example environment for the LMS starter kit.
# Copy to `.env` and fill in values. Never commit real secrets — `.env` is gitignored.
# Every config parameter decided in the specs lives here (see CLAUDE.md → Configuration & env).

# ─── App ──────────────────────────────────────────────────────────────────────
# Runtime environment. The initial-Admin bootstrap seed runs in dev and is SKIPPED
# when APP_ENV=prod. (spec 001-foundation-skeleton, FR-006)
APP_ENV=dev

# Host port the admin panel binds to. Defaults off 3000 to dodge other local
# projects; change it if this one is also taken. `docker compose up` fails fast
# on a port conflict. (FR-002, edge case)
APP_PORT=3021

# ─── Initial Admin (dev) ──────────────────────────────────────────────────────
# Used by the bootstrap seed to create the first Admin. If left unset, the seed
# falls back to dev-only defaults and warns you to set a real password here.
# Never commit real credentials. (FR-004, FR-006)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-dev

# ─── Stack: Payload + Postgres ────────────────────────────────────────────────
# Required by the constitution-fixed stack. Exact shape (compose service host, db name)
# is finalized during /speckit-plan; placeholders below.
# Postgres connection string used by Payload.
DATABASE_URI=postgres://postgres:postgres@db:5432/lms
# Payload secret for signing tokens/cookies — set a long random value; never commit a real one.
PAYLOAD_SECRET=replace-with-a-long-random-string
